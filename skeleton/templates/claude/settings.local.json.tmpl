{
  "permissions": {
    "allow": [
      "Bash(bash web/start-dashboard.sh)",
      "Bash(bash web/stop-dashboard.sh)",
      "Bash(open http://localhost:{{DASHBOARD_PORT}})",
      "Bash(curl *localhost:{{DASHBOARD_PORT}}/api/*)",
      "Bash(bash scripts/*)",
      "Bash(bash plugins/*/start.sh *)",
      "Bash(bash plugins/*/stop.sh *)",
      "Bash(bash plugins/*/reply.sh *)",
      "Bash(bash plugins/*/notify.sh *)",
      "Bash(bash plugins/*/report.sh *)",
      "Bash(bash setup.sh)",
      "Bash(jq *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(echo *)",
      "Bash(for *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(python3 *)",
      "Bash(nohup *)",
      "Bash(kill *)",
      "Bash(lsof *)",
      "Bash(ps *)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(source *)",
      "Bash(file *)",
      "Bash(chmod *)",
      "Bash(ssh *)",
      "Bash(scp *)",
      "Bash(curl:*)",
      "Bash(ping *)",
      "Bash(dig *)",
      "Bash(nc *)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/prompt-check.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/learning-reflect.sh\""
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/idle-learn.sh\""
          }
        ]
      }
    ]
  }
}
