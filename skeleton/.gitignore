# 运行时数据（日志、快照、报告）
data/logs/*
data/snapshots/*
data/reports/*
!data/logs/.gitkeep
!data/snapshots/.gitkeep
!data/reports/.gitkeep
data/cf-reports/*
!data/cf-reports/.gitkeep

# 环境配置
.env
.env.local

# Claude Code 本地配置
.claude/

# OS
.DS_Store
Thumbs.db

# Plugins sensitive data
plugins/feishu-auth/tokens.json

# 隐私数据
memory/private/
!memory/private/.gitkeep

# Node / Dashboard
node_modules/
web/node_modules/
web/.dashboard.pid
web/dashboard.log
