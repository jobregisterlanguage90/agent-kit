# === Cloudflare 监控（必填）===
CF_API_TOKEN=""
CF_ZONE_ID_NOUHAUS=""

# === Cloudflare WAF 规则 ID（monitor-cloudflare Skill 使用）===
CF_WAF_RULESET_ID=""
CF_WAF_ASN_RULE_ID=""

# === VPN 管理（可选，scripts/vpn.sh 使用）===
CF_ZONE_ID_ARTUX=""
VPN1_INSTANCE_ID=""
VPN1_REGION="us-east-1"
VPN1_DNS_RECORD_ID=""
VPN1_DOMAIN=""
VPN2_INSTANCE_ID=""
VPN2_REGION="ap-northeast-2"
VPN2_DNS_RECORD_ID=""
VPN2_DOMAIN=""
VPN3_INSTANCE_ID=""
VPN3_REGION="us-west-2"
VPN3_DNS_RECORD_ID=""
VPN3_DOMAIN=""

# === 代理服务（可选）===
SS_PASSWORD=""
VLESS_UUID=""

# === 飞书汇报（可选）===
# 企业自建应用 — 需开通 bitable:app + im:message:send_as_bot 权限
FEISHU_APP_ID=""
FEISHU_APP_SECRET=""
# 多维表格：从文档 URL /base/ 后取 app_token，进每张表获取 table_id
FEISHU_BITABLE_APP_TOKEN=""
FEISHU_CF_TABLE_ID=""         # CF 安全巡检表
FEISHU_SERVER_TABLE_ID=""     # 服务器健康表
FEISHU_WAF_TABLE_ID=""        # WAF 变更日志表
FEISHU_DEPLOY_TABLE_ID=""     # 部署记录表
FEISHU_PERF_TABLE_ID=""       # 网站性能监控表
# 群自定义机器人 Webhook（异常/WAF 变更时推送卡片）
FEISHU_WEBHOOK_URL=""
# 学习成果通知 — 发到独立群（chat_id），文档存到指定文件夹（folder_token）
FEISHU_LEARNING_CHAT_ID=""         # 群 chat_id（从 IM API 获取）
FEISHU_LEARNING_FOLDER_TOKEN=""    # 飞书云文档文件夹 token（fallback，优先用 Wiki）
FEISHU_WIKI_SPACE_ID=""            # 学习知识库 space_id（需 user_access_token，见 plugins/feishu-auth/）
FEISHU_PERF_WIKI_SPACE_ID=""       # 性能报告知识库 space_id
# 巡检 Zone 标签（显示在 Bitable 记录中，默认 nouhaus.com）
CF_ZONE_LABEL="nouhaus.com"

# === 性能监控（可选）===
PERF_CHECK_INTERVAL=21600                    # 默认 6 小时
PERF_TARGET_URLS="https://nouhaus.com"       # 逗号分隔的目标 URL

# === SSL 监控（可选）===
SSL_CHECK_DOMAINS="spukit.artux.ai"          # 逗号分隔，Shopify 域名不需要
SSL_WARN_DAYS=14                              # 过期前 N 天告警

# === SEO 监控（可选）===
SEO_CHECK_DOMAINS="nouhaus.com,artux.ai"     # 逗号分隔的域名
# Google Search Console（未来，需 OAuth 配置）
# GOOGLE_APPLICATION_CREDENTIALS=""

# === 统一监控守护进程（可选）===
MONITOR_CF_ENABLED=true
MONITOR_PERF_ENABLED=true
MONITOR_SSL_ENABLED=true
MONITOR_SEO_ENABLED=false
MONITOR_CF_INTERVAL=7200                     # CF 巡检间隔（默认 2 小时）
MONITOR_PERF_INTERVAL=21600                  # 性能检查间隔（默认 6 小时）
MONITOR_SSL_INTERVAL=86400                   # SSL 检查间隔（默认 24 小时）
MONITOR_SEO_INTERVAL=86400                   # SEO 检查间隔（默认 24 小时）

# === Dashboard（可选）===
DASHBOARD_PORT=7890
