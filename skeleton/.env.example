# ========================================
# Agent 项目环境配置
# 复制为 .env 并填写
# ========================================

# === 基础配置（必填）===
# Dashboard 端口（默认 7890，如果该端口已被占用请修改）
# 同一台机器运行多个 Kit 项目时，每个项目需要不同端口（如 7890, 7891, 7892）
DASHBOARD_PORT={{DASHBOARD_PORT}}

# === 跨进程通信（可选）===
CROSS_PROCESS_ENABLED=false
CROSS_PROCESS_PEERS=""    # 逗号分隔的端口号，如 "7890,7891"

# === 监控守护进程（可选）===
MONITOR_DAEMON_ENABLED=false
MONITOR_CHECK_INTERVAL=3600    # 秒

# === 以下配置按需启用 ===
# 取消注释并填写需要的配置

# --- 飞书通知 ---
# FEISHU_APP_ID=""
# FEISHU_APP_SECRET=""
# FEISHU_WEBHOOK_URL=""
# FEISHU_NOTIFY_CHAT_ID=""

# --- Webhook 通知 ---
# WEBHOOK_URL=""
# WEBHOOK_TYPE="feishu"    # feishu | slack | discord | custom
